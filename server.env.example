# Mac 서버에서 setup-turn-mac.command를 실행하면 server.env가 자동 생성됩니다.
# Windows/Parallels/외부 클라이언트가 Mac 서버에 붙을 때 relay candidate가 없으면 TURN을 확인하세요.

# Comma separated STUN URLs. Leave this if you do not know what to use.
STUN_URLS=stun:stun.l.google.com:19302,stun:stun.cloudflare.com:3478

# Mac에서 Docker coturn을 띄운 경우 setup script가 아래 값을 채웁니다.
TURN_URLS=turn:YOUR_MAC_HOST:3478?transport=udp,turn:YOUR_MAC_HOST:3478?transport=tcp
TURN_USERNAME=your-turn-username
TURN_CREDENTIAL=your-turn-password
